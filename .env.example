PORT=4000

# Tek satır URL kullanmak istersen:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# Veya ayrı alanlar:
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password
PGDATABASE=postgres

# local postgres SSL gerektiriyorsa:
# PGSSLMODE=require

# Three.js frontend origin (Vite default)
CORS_ORIGIN=http://localhost:5173

# Supabase/Vercel için notlar:
# - Supabase Postgres kullanıyorsan genelde DATABASE_URL verirsin
# - Supabase remote bağlantıda çoğu zaman SSL gerekir
#   PGSSLMODE=require
# - Vercel deploy'da CORS_ORIGIN'i genellikle '*' yapabilirsin (frontend aynı domainde çalışacak)

